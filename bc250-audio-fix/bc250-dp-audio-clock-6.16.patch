--- a/drivers/gpu/drm/amd/display/amdgpu_dm/amdgpu_dm.c
+++ b/drivers/gpu/drm/amd/display/amdgpu_dm/amdgpu_dm.c
@@ -2033,6 +2033,12 @@
 
 	init_data.flags.enable_mipi_converter_optimization = true;
 
+	/* Cyan Skillfish VBIOS carries no DP spread-spectrum entry; the
+	 * fallback SS data would skew the DP reference clock and audio DTO.
+	 */
+	if (amdgpu_ip_version(adev, DCE_HWIP, 0) == IP_VERSION(2, 0, 3))
+		init_data.flags.ignore_dpref_ss = true;
+
 	init_data.dcn_reg_offsets = adev->reg_offset[DCE_HWIP][0];
 	init_data.nbio_reg_offsets = adev->reg_offset[NBIO_HWIP][0];
 	init_data.clk_reg_offsets = adev->reg_offset[CLK_HWIP][0];
--- a/drivers/gpu/drm/amd/display/dc/clk_mgr/clk_mgr.c
+++ b/drivers/gpu/drm/amd/display/dc/clk_mgr/clk_mgr.c
@@ -253,6 +253,15 @@
 			BREAK_TO_DEBUGGER();
 			return NULL;
 		}
+		/* DCN 2.01 (Cyan Skillfish/BC-250) must be checked before the
+		 * Beige Goby rev range below, which is open-ended and matches
+		 * Cyan Skillfish's 0x82+ internal rev. Backport of upstream
+		 * commit 9c7be0efa6f0 ("drm/amd: fix dcn 2.01 check").
+		 */
+		if (ctx->dce_version == DCN_VERSION_2_01) {
+			dcn201_clk_mgr_construct(ctx, clk_mgr, pp_smu, dccg);
+			return &clk_mgr->base;
+		}
 		if (ASICREV_IS_SIENNA_CICHLID_P(asic_id.hw_internal_rev)) {
 			dcn3_clk_mgr_construct(ctx, clk_mgr, pp_smu, dccg);
 			return &clk_mgr->base;
@@ -265,10 +273,6 @@
 			dcn3_clk_mgr_construct(ctx, clk_mgr, pp_smu, dccg);
 			return &clk_mgr->base;
 		}
-		if (ctx->dce_version == DCN_VERSION_2_01) {
-			dcn201_clk_mgr_construct(ctx, clk_mgr, pp_smu, dccg);
-			return &clk_mgr->base;
-		}
 		dcn20_clk_mgr_construct(ctx, clk_mgr, pp_smu, dccg);
 		return &clk_mgr->base;
 	}
